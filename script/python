#!/bin/bash

# script/python: Format and lint Python files
#
# Runs Ruff format (auto-format) and Ruff check with auto-fix enabled.
# Targets Python files under custom_components/ and tests/ only.
#
# Usage:
#   ./script/python
#
# Examples:
#   ./script/python

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

# shellcheck source=script/.lib/output.sh
source "$SCRIPT_DIR/.lib/output.sh"

activate_venv

run_hook "python" "pre"

log_header "Running Ruff format"
ruff format custom_components/ tests/

log_header "Running Ruff check"
ruff check custom_components/ tests/ --fix

# Clean up any accidental package installation from uv run
"$SCRIPT_DIR/clean" --minimal

run_hook "python" "post"
log_success "Python formatting and linting completed"
