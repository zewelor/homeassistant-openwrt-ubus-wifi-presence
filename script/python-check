#!/bin/bash

# script/python-check: Check Python formatting and linting without making changes
#
# Runs Ruff format in check-only mode and Ruff check without auto-fix.
# Targets Python files under custom_components/ and tests/ only.
# Useful for CI/CD and targeted validation after Python changes.
#
# Usage:
#   ./script/python-check
#
# Examples:
#   ./script/python-check

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

# shellcheck source=script/.lib/output.sh
source "$SCRIPT_DIR/.lib/output.sh"

activate_venv

run_hook "python-check" "pre"

log_header "Checking Python format (Ruff)"
ruff format custom_components/ tests/ --check

log_header "Checking Python linting (Ruff)"
ruff check custom_components/ tests/

# Clean up any accidental package installation from uv run
"$SCRIPT_DIR/clean" --minimal

run_hook "python-check" "post"
log_success "Python check completed"
