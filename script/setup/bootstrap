#!/bin/bash

# script/bootstrap: Install/update all dependencies required to run the project
#
# Bootstraps the development environment by installing system packages,
# setting up uv package manager, creating virtual environment, and installing
# Python dependencies including Home Assistant core and development tools.
#
# Usage:
#   ./script/setup/bootstrap
#
# Examples:
#   ./script/setup/bootstrap

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/../.."

# shellcheck source=script/.lib/output.sh
source "$SCRIPT_DIR/../.lib/output.sh"
# shellcheck source=script/.lib/download.sh
source "$SCRIPT_DIR/../.lib/download.sh"
# shellcheck source=script/.lib/ha_version.sh
source "$SCRIPT_DIR/../.lib/ha_version.sh"

# Load environment overrides in two layers (later layers win):
#   .devcontainer/.env       — project-level defaults, committed to the repo
#   .devcontainer/.env.local — user/machine-specific overrides, gitignored
# See .devcontainer/.env.local.example for available options.
_env_file=".devcontainer/.env"
if [[ -f "$_env_file" ]]; then
    log_info "Loading project overrides from .devcontainer/.env"
    # shellcheck source=/dev/null
    source "$_env_file"
fi
unset _env_file
_env_local=".devcontainer/.env.local"
if [[ -f "$_env_local" ]]; then
    log_info "Loading local overrides from .devcontainer/.env.local"
    # shellcheck source=/dev/null
    source "$_env_local"
fi
unset _env_local

run_hook "setup/bootstrap" "pre"

if [[ ${APT_UPDATE:-"0"} == "1" ]]; then
    log_header "Updating system packages"
    sudo apt-get update
    sudo apt-get upgrade -y
fi

log_header "Checking for uv"
if ! command -v uv >/dev/null 2>&1; then
    log_info "UV not found, installing..."
    pipx install uv
fi

log_header "Checking for Python virtual environment"

# Determine venv location based on environment
# In DevContainer: Use $HOME/ha-venv (named volume mounted directly in $HOME, avoids Docker creating ~/.local as root)
# Local development: Use .local/ha-venv in workspace (isolated per project)
# CI (GitHub Actions): Use workspace .local/ha-venv (both work)
if [[ -n "${REMOTE_CONTAINERS:-}" || -n "${CODESPACES:-}" ]]; then
    # Running in DevContainer or Codespaces
    VENV_PATH="$HOME/ha-venv"
    VENV_IS_EXTERNAL=true
    log_info "DevContainer/Codespaces detected - using external venv"
elif [[ -n "${GITHUB_ACTIONS:-}" ]]; then
    # Running in GitHub Actions
    VENV_PATH="${GITHUB_WORKSPACE:-.}/.local/ha-venv"
    VENV_IS_EXTERNAL=false
    log_info "GitHub Actions detected - using workspace venv"
else
    # Local development (Mac, Linux, WSL)
    VENV_PATH=".local/ha-venv"
    VENV_IS_EXTERNAL=false
    log_info "Local development detected - using workspace venv"
fi

if [[ ! -d "$VENV_PATH" ]]; then
    log_info "Creating virtual environment at $VENV_PATH"
    uv venv "$VENV_PATH"
elif [[ ! -x "$VENV_PATH/bin/python3" ]]; then
    # Venv exists but python3 is broken (broken symlink or missing).
    # Use find instead of rm -rf: the path may be a named Docker volume mount point
    # which cannot be removed itself — only its contents can be deleted.
    log_warning "Existing venv has broken Python interpreter - recreating"
    find "$VENV_PATH" -mindepth 1 -delete
    log_info "Creating virtual environment at $VENV_PATH"
    uv venv "$VENV_PATH"
fi

# Create symlinks for IDE compatibility and tool expectations
if [[ "$VENV_IS_EXTERNAL" == "true" ]]; then
    # DevContainer: Create symlink from workspace to external venv
    log_step "Creating workspace symlink for IDE type checking"
    mkdir -p .local
    # .local/ha-venv → /home/vscode/ha-venv (absolute path - simpler and more reliable)
    if [[ -d .local/ha-venv && ! -L .local/ha-venv ]]; then
        log_warning "Skipping .local/ha-venv: directory already exists (not a symlink)"
    else
        ln -sf "$VENV_PATH" .local/ha-venv
    fi
fi

# Create compatibility symlinks for common venv locations (all environments)
log_step "Creating compatibility symlinks for tool expectations"
mkdir -p .local

# .venv → .local/ha-venv (Python/uv standard location)
if [[ -d .venv && ! -L .venv ]]; then
    log_warning "Skipping .venv: directory already exists (not a symlink)"
else
    ln -sf .local/ha-venv .venv
fi

# .local/venv → ha-venv (GitHub Copilot Agent expectation)
if [[ -d .local/venv && ! -L .local/venv ]]; then
    log_warning "Skipping .local/venv: directory already exists (not a symlink)"
else
    ln -sf ha-venv .local/venv
fi

# shellcheck source=/dev/null
source "$VENV_PATH/bin/activate"

# Auto-activate venv in shell RC files (only in DevContainer/Codespaces where venv is external)
if [[ "$VENV_IS_EXTERNAL" == "true" ]]; then
    set +e
    if [[ -f $HOME/.bashrc ]]; then
        if ! grep -q "source $VENV_PATH/bin/activate" "$HOME/.bashrc" 2>/dev/null; then
            log_step "Configuring Bash to auto-activate virtual environment"
            echo "source $VENV_PATH/bin/activate" >>"$HOME/.bashrc" || log_warning "Failed to update .bashrc"
        fi
        # Source .env files so their variables are available in every interactive terminal,
        # equivalent to containerEnv variables set in devcontainer.json.
        # .env.local is sourced after .env so user overrides win.
        if ! grep -q "devcontainer/.env" "$HOME/.bashrc" 2>/dev/null; then
            log_step "Configuring Bash to source DevContainer environment files"
            cat >>"$HOME/.bashrc" <<'EOF'
# DevContainer environment overrides (.env → .env.local, later wins)
# set -a auto-exports all variables so child processes (hass, pytest, uv) see them too.
if [ -n "$WORKSPACE_ROOT" ]; then
    set -a
    [ -f "$WORKSPACE_ROOT/.devcontainer/.env" ] && source "$WORKSPACE_ROOT/.devcontainer/.env"
    [ -f "$WORKSPACE_ROOT/.devcontainer/.env.local" ] && source "$WORKSPACE_ROOT/.devcontainer/.env.local"
    set +a
fi
EOF
        fi
    fi
    if [[ -f $HOME/.zshrc ]]; then
        if ! grep -q "source $VENV_PATH/bin/activate" "$HOME/.zshrc"; then
            log_step "Configuring ZSH to auto-activate virtual environment"
            echo "source $VENV_PATH/bin/activate" >>"$HOME/.zshrc" || log_warning "Failed to update .zshrc"
        fi
        if ! grep -q "devcontainer/.env" "$HOME/.zshrc" 2>/dev/null; then
            log_step "Configuring ZSH to source DevContainer environment files"
            cat >>"$HOME/.zshrc" <<'EOF'
# DevContainer environment overrides (.env → .env.local, later wins)
# set -a auto-exports all variables so child processes (hass, pytest, uv) see them too.
if [ -n "$WORKSPACE_ROOT" ]; then
    set -a
    [ -f "$WORKSPACE_ROOT/.devcontainer/.env" ] && source "$WORKSPACE_ROOT/.devcontainer/.env"
    [ -f "$WORKSPACE_ROOT/.devcontainer/.env.local" ] && source "$WORKSPACE_ROOT/.devcontainer/.env.local"
    set +a
fi
EOF
        fi
    fi
    set -e
fi

log_header "Installing development dependencies"
uv pip install --requirement requirements_dev.txt

log_header "Installing test dependencies"
uv pip install --requirement requirements_test.txt

log_header "Installing runtime dependencies"
if [[ -s requirements.txt ]] && grep -qv '^#' requirements.txt | grep -q '[^[:space:]]'; then
    uv pip install --requirement requirements.txt
else
    log_info "No runtime dependencies defined (this is normal for blueprints)"
fi

if [[ -f requirements.local.txt ]]; then
    log_header "Installing local extra dependencies (requirements.local.txt)"
    uv pip install --requirement requirements.local.txt
fi

if [[ -n "${HA_VERSION:-}" ]]; then
    # Explicit HA_VERSION from environment — use exactly as specified
    resolve_ha_version HA_VERSION "$HA_VERSION"
else
    # Read from hacs.json: treat YEAR.MONTH.0 as YEAR.MONTH so the latest
    # stable patch is installed (hacs.json records minimum version, not pin)
    HA_VERSION=$(grep '"homeassistant"' hacs.json | head -1 | sed 's/.*"homeassistant"\s*:\s*"\([^"]*\)".*/\1/')
    if [[ -z "$HA_VERSION" ]]; then
        log_error "HA_VERSION not set and could not be determined from hacs.json"
        exit 1
    fi
    if [[ "$HA_VERSION" =~ ^[0-9]{4}\.[0-9]+\.0$ ]]; then
        HA_VERSION="${HA_VERSION%.*}" # "2026.4.0" → "2026.4" → latest patch
    fi
    resolve_ha_version HA_VERSION "$HA_VERSION"
fi

HA_CORE_BASE_URL="https://raw.githubusercontent.com/home-assistant/core/${HA_VERSION}"

# Recreate the venv if the installed HA version no longer matches the target.
# This handles the cached-volume case: the venv persists across rebuilds, so without
# this check an HA version bump would silently run on the old installation.
# The marker file ($VENV_PATH/.ha-version) is written after a successful install below.
HA_VERSION_MARKER="$VENV_PATH/.ha-version"
if [[ -f "$HA_VERSION_MARKER" ]]; then
    CACHED_HA_VERSION=$(cat "$HA_VERSION_MARKER")
    if [[ "$CACHED_HA_VERSION" != "$HA_VERSION" ]]; then
        log_warning "HA version changed ($CACHED_HA_VERSION → $HA_VERSION) — recreating virtual environment"
        # Use find instead of rm -rf: the path may be a named Docker volume mount point
        # which cannot be removed itself — only its contents can be deleted.
        find "$VENV_PATH" -mindepth 1 -delete
        uv venv "$VENV_PATH"
        # shellcheck source=/dev/null
        source "$VENV_PATH/bin/activate"
    fi
fi

log_header "Installing Home Assistant ${HA_VERSION} runtime dependencies"
mkdir -p "/tmp/homeassistant"
_download "${HA_CORE_BASE_URL}/homeassistant/package_constraints.txt" "/tmp/homeassistant/package_constraints.txt" # constraints for requirements files
_download "${HA_CORE_BASE_URL}/requirements.txt" "/tmp/requirements.txt"                                           # required by requirements_all.txt
_download "${HA_CORE_BASE_URL}/requirements_all.txt" "/tmp/requirements_all.txt"
uv pip install --requirement "/tmp/requirements_all.txt"

log_header "Installing Home Assistant ${HA_VERSION} test dependencies"
_download "${HA_CORE_BASE_URL}/requirements_test_pre_commit.txt" "/tmp/requirements_test_pre_commit.txt" # required by requirements_test.txt
_download "${HA_CORE_BASE_URL}/requirements_test.txt" "/tmp/requirements_test.txt"
uv pip install --requirement "/tmp/requirements_test.txt"

log_header "Installing Home Assistant ${HA_VERSION} core"
uv pip install "homeassistant==${HA_VERSION}"

# Record the installed HA version so bootstrap can detect version changes on subsequent runs.
echo "$HA_VERSION" >"$HA_VERSION_MARKER"

set +e
rm -rf /tmp/requirements*.txt /tmp/homeassistant/ || log_warning "Failed to clean up temporary files"
set -e

log_header "Installing Node.js dependencies"
if command -v npm >/dev/null 2>&1; then
    # node_modules is kept off the bind mount via a named Docker volume (devcontainer.json).
    # Docker creates named volumes owned by root — fix ownership before npm ci writes into it.
    if [[ -d node_modules && "$(stat -c %U node_modules 2>/dev/null)" == "root" ]]; then
        log_step "Fixing node_modules ownership (Docker volume created as root)"
        sudo chown "$(id -un):$(id -gn)" node_modules
    fi
    npm ci --silent
else
    log_warning "npm not found — skipping Node.js dependency installation"
    log_info "Install Node.js to enable: prettier, markdownlint-cli2"
fi

# Only install pre-commit hooks in local development, not in CI
# GITHUB_ACTIONS is always set to "true" in GitHub Actions environments
if [[ -d ".git" && -z "${GITHUB_ACTIONS:-}" ]]; then
    log_header "Installing pre-commit hooks"
    set +e
    pre-commit install || log_warning "Failed to install pre-commit hooks"
    set -e
else
    if [[ -n "${GITHUB_ACTIONS:-}" ]]; then
        log_info "Skipping pre-commit hooks (running in GitHub Actions)"
    else
        log_info "Skipping pre-commit hooks (not a Git repository)"
    fi
fi

log_header "Pruning uv package cache"
# Remove cache entries that are no longer referenced by any installed environment.
# Safe to run after every install; avoids unbounded cache growth on the named Docker volume.
uv cache prune --quiet

run_hook "setup/bootstrap" "post"
log_success "Bootstrap complete"
