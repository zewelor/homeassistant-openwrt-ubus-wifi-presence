#!/bin/bash

# script/dead-code: Check for potentially unused code symbols
#
# Runs vulture against integration and tests to catch dead code that lint/type
# checks do not detect (for example unused constants or helper methods).
#
# Usage:
#   ./script/dead-code

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

# shellcheck source=script/.lib/output.sh
source "$SCRIPT_DIR/.lib/output.sh"

if [[ -z ${VIRTUAL_ENV:-} ]]; then
    log_header "Activating virtual environment"
    # shellcheck source=/dev/null
    if [[ -f "$HOME/.local/ha-venv/bin/activate" ]]; then
        source "$HOME/.local/ha-venv/bin/activate"
    elif [[ -f "$PWD/.local/ha-venv/bin/activate" ]]; then
        source "$PWD/.local/ha-venv/bin/activate"
    else
        log_error "Virtual environment not found"
        log_info "Run: ./script/setup/bootstrap"
        exit 1
    fi
fi

log_header "Checking dead code with Vulture"

if ! command -v vulture >/dev/null 2>&1; then
    log_error "vulture is not installed"
    log_info "Run: ./script/setup/bootstrap"
    exit 1
fi

if vulture custom_components/openwrt_ubus tests --min-confidence 90 --ignore-names enable_custom_integrations; then
    log_success "Dead code check completed"
else
    log_error "Dead code check failed"
    exit 1
fi
