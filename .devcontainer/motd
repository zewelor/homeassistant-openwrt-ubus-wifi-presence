#!/usr/bin/env bash

# .devcontainer/motd: Display Message of the Day for development environment
#
# Displays welcome message with project info and available scripts.
# Called automatically by shell configuration on first terminal.
#
# Usage:
#   ./script/motd
#
# Examples:
#   ./script/motd

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

# shellcheck source=script/.lib/output.sh
source "$SCRIPT_DIR/../script/.lib/output.sh"

REPO_NAME=$(basename "$(git rev-parse --show-toplevel 2>/dev/null)" 2>/dev/null || basename "$(pwd)")
RUNTIME_MODE="Dev Container"
if [[ -n "${CODESPACES:-}" ]]; then
    RUNTIME_MODE="Codespaces"
elif [[ -n "${SSH_CONNECTION:-}" ]]; then
    RUNTIME_MODE="Remote SSH"
fi

print_banner() {
    local text="$1"
    local width=78
    local text_len=${#text}
    local pad_left=$(((width - text_len) / 2))
    local pad_right=$((width - text_len - pad_left))
    local left_spaces right_spaces
    left_spaces=$(printf "%${pad_left}s" "")
    right_spaces=$(printf "%${pad_right}s" "")

    printf "%b+------------------------------------------------------------------------------+%b\n" "$BLUE" "$NC"
    printf "%b|                                                                              |%b\n" "$BLUE" "$NC"
    printf "%b|%s%s%s|%b\n" "$BLUE" "$left_spaces" "$text" "$right_spaces" "$NC"
    printf "%b|                                                                              |%b\n" "$BLUE" "$NC"
    printf "%b+------------------------------------------------------------------------------+%b\n" "$BLUE" "$NC"
}

echo ""
print_banner "Welcome to ${REPO_NAME} (${RUNTIME_MODE})"
echo ""
printf "%b%b Project:%b %s\n" "$DIM" "$PACKAGE" "$NC" "$(pwd)"
printf "%b%b Git branch:%b %s\n" "$DIM" "$ARROW" "$NC" "$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'Not a git repo')"
printf "%b%b Python:%b %s\n" "$DIM" "$WRENCH" "$NC" "$(python3 --version 2>/dev/null || echo 'Not available')"
echo ""

printf "%b%b Quick start:%b %bscript/develop%b -> %bscript/check%b -> %bscript/test%b\n" "$CYAN" "$INFO" "$NC" "$BOLD" "$NC" "$BOLD" "$NC" "$BOLD" "$NC"
printf "%b%b Logs:%b live in develop terminal, file at %bconfig/home-assistant.log%b\n" "$CYAN" "$INFO" "$NC" "$BOLD" "$NC"

if [[ "$RUNTIME_MODE" == "Codespaces" ]]; then
    printf "%b%b Access:%b use forwarded port 8123 (Ports panel if browser does not open)\n" "$CYAN" "$INFO" "$NC"
elif [[ "$RUNTIME_MODE" == "Remote SSH" ]]; then
    printf "%b%b Access:%b localhost:8123 requires SSH/VS Code port forwarding\n" "$CYAN" "$INFO" "$NC"
else
    printf "%b%b Access:%b open %bhttp://localhost:8123%b\n" "$CYAN" "$INFO" "$NC" "$BOLD" "$NC"
fi
echo ""

"$SCRIPT_DIR/../script/help"

echo ""
printf "%b%b Tip:%b This greeting is shown once per new/rebuilt container.\n" "$CYAN" "$INFO" "$NC"
echo ""
