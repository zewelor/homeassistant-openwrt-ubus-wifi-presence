# .devcontainer/.env.local — Local DevContainer environment overrides
#
# Copy this file to .devcontainer/.env.local and uncomment the vars you want
# to override. The file is gitignored so your changes won't affect others or
# conflict with blueprint updates to devcontainer.json or .env.
#
# Two-layer override system (later layers win):
#   .devcontainer/.env       — project-level defaults, committed to the repo
#   .devcontainer/.env.local — your personal overrides (this file), gitignored
#
# Both files are sourced early in script/setup/bootstrap and script/setup/setup,
# so values set here take precedence over .env.
#
# ⚠ SCOPE LIMITATION: Variables here reach lifecycle hook scripts and interactive
# shell sessions only. They do NOT reach DevContainer features (image build time)
# or containerEnv. To change feature versions (Python, Node), edit devcontainer.json.
#
# After changing this file, run "Dev Containers: Rebuild Container" to apply.
#

# ── Home Assistant version ────────────────────────────────────────────────────
# Pin to a specific HA version instead of the one from hacs.json.
# Supported values:
#   "latest"        → newest stable release
#   "beta"          → newest pre-release (alpha/beta/RC)
#   "YEAR.MONTH"    → latest patch for that month  (e.g. "2026.4")
#   "YEAR.MONTH.N"  → exact stable version         (e.g. "2026.4.2")
#   "YEAR.MONTH.NbM"→ exact pre-release            (e.g. "2026.4.0b1")
# If unset, defaults to the version in hacs.json (resolved to latest patch).
#
# HA_VERSION=2026.4

# ── HACS installation ─────────────────────────────────────────────────────────
# Set to "0" to skip HACS installation (speeds up setup if you don't need it).
# Default: "1" (install HACS)
#
# HA_INSTALL_HACS=0

# ── System package updates ────────────────────────────────────────────────────
# Set to "1" to run apt-get update/upgrade during setup (useful in older images).
# Default: "0" (skip)
#
# APT_UPDATE=0
